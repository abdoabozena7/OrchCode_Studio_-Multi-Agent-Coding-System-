{
  "name": "hivo-studio",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/agent-runtime",
    "apps/desktop",
    "packages/protocol"
  ],
  "scripts": {
    "build": "npm run build -w @hivo/protocol && npm run build -w @hivo/agent-runtime && npm run build -w @hivo/desktop",
    "typecheck": "npm run build -w @hivo/protocol && npm run typecheck -w @hivo/protocol && npm run typecheck -w @hivo/agent-runtime && npm run typecheck -w @hivo/desktop",
    "test": "npm run test -w @hivo/agent-runtime",
    "smoke:desktop-run-project": "npm run smoke:run-project -w @hivo/desktop",
    "smoke:terminal-authority": "npm run smoke:run-project -w @hivo/desktop",
    "smoke:run-to-green": "npm run smoke:run-to-green -w @hivo/agent-runtime",
    "smoke:inspect-provider-truth": "npm run smoke:inspect-provider-truth -w @hivo/agent-runtime",
    "smoke:python-pygame-fallback": "npm run smoke:python-pygame-fallback -w @hivo/agent-runtime",
    "memory:index": "tsx apps/agent-runtime/src/memory/cli.ts index repo --workspace .",
    "memory:index-status": "tsx apps/agent-runtime/src/memory/cli.ts index status --workspace .",
    "memory:index-refresh": "tsx apps/agent-runtime/src/memory/cli.ts index refresh --workspace .",
    "memory:index-explain": "tsx apps/agent-runtime/src/memory/cli.ts index explain --workspace .",
    "memory:inspect": "tsx apps/agent-runtime/src/memory/cli.ts memory inspect --workspace .",
    "memory:status": "tsx apps/agent-runtime/src/memory/cli.ts memory status --workspace .",
    "memory:show-commands": "tsx apps/agent-runtime/src/memory/cli.ts memory show-commands --workspace .",
    "memory:clean-runs": "tsx apps/agent-runtime/src/memory/cli.ts memory clean-runs --workspace .",
    "memory:compact": "tsx apps/agent-runtime/src/memory/cli.ts memory compact --workspace .",
    "memory:lessons": "tsx apps/agent-runtime/src/memory/cli.ts memory lessons --workspace .",
    "memory:decisions": "tsx apps/agent-runtime/src/memory/cli.ts memory decisions --workspace .",
    "memory:failed-attempts": "tsx apps/agent-runtime/src/memory/cli.ts memory failed-attempts --workspace .",
    "memory:explain-task": "tsx apps/agent-runtime/src/memory/cli.ts memory explain-task --workspace .",
    "agent:run": "tsx apps/agent-runtime/src/orchestration/cli.ts agent run --workspace .",
    "agent:plan": "tsx apps/agent-runtime/src/orchestration/cli.ts agent plan --workspace .",
    "agent:inspect-run": "tsx apps/agent-runtime/src/orchestration/cli.ts agent inspect-run --workspace .",
    "agent:report": "tsx apps/agent-runtime/src/orchestration/cli.ts agent report --workspace .",
    "agent:resume": "tsx apps/agent-runtime/src/orchestration/cli.ts agent resume --workspace .",
    "agent:trial:architecture-scan": "tsx apps/agent-runtime/src/orchestration/cli.ts agent trial architecture-scan --workspace .",
    "agent:trial:test-discovery": "tsx apps/agent-runtime/src/orchestration/cli.ts agent trial test-discovery --workspace .",
    "agent:trial:staffing-eval": "tsx apps/agent-runtime/src/orchestration/cli.ts agent trial staffing-eval --workspace .",
    "agent:trial:scheduler-scale": "tsx apps/agent-runtime/src/orchestration/cli.ts agent trial scheduler-scale --workspace .",
    "agent:trial:compare": "tsx apps/agent-runtime/src/orchestration/cli.ts agent trial compare --workspace .",
    "agent:trial:small-safe-fix": "tsx apps/agent-runtime/src/orchestration/cli.ts agent trial small-safe-fix --workspace .",
    "agent:trial:huge-readonly-scan": "tsx apps/agent-runtime/src/orchestration/cli.ts agent trial huge-readonly-scan --workspace .",
    "agentic:run": "tsx apps/agent-runtime/src/orchestration/cli.ts run-agentic-task --workspace .",
    "agentic:plan": "tsx apps/agent-runtime/src/orchestration/cli.ts plan-task --workspace .",
    "agentic:resume-run": "tsx apps/agent-runtime/src/orchestration/cli.ts resume-run --workspace .",
    "agentic:list-runs": "tsx apps/agent-runtime/src/orchestration/cli.ts list-runs --workspace .",
    "agentic:show-run": "tsx apps/agent-runtime/src/orchestration/cli.ts show-run --workspace .",
    "agentic:show-report": "tsx apps/agent-runtime/src/orchestration/cli.ts show-report --workspace .",
    "agentic:run-metrics": "tsx apps/agent-runtime/src/orchestration/cli.ts run-metrics --workspace .",
    "agentic:show-artifacts": "tsx apps/agent-runtime/src/orchestration/cli.ts show-artifacts --workspace .",
    "agentic:show-artifact": "tsx apps/agent-runtime/src/orchestration/cli.ts show-artifact --workspace .",
    "agentic:inspect-task": "tsx apps/agent-runtime/src/orchestration/cli.ts inspect-task --workspace .",
    "agentic:show-context-pack": "tsx apps/agent-runtime/src/orchestration/cli.ts show-context-pack --workspace .",
    "agentic:show-run-events": "tsx apps/agent-runtime/src/orchestration/cli.ts show-run-events --workspace .",
    "agentic:show-task-artifacts": "tsx apps/agent-runtime/src/orchestration/cli.ts show-task-artifacts --workspace .",
    "agentic:show-validation-logs": "tsx apps/agent-runtime/src/orchestration/cli.ts show-validation-logs --workspace .",
    "agentic:show-patch-history": "tsx apps/agent-runtime/src/orchestration/cli.ts show-patch-history --workspace .",
    "campaign:create": "tsx apps/agent-runtime/src/orchestration/campaign-cli.ts create --workspace .",
    "campaign:plan": "tsx apps/agent-runtime/src/orchestration/campaign-cli.ts plan --workspace .",
    "campaign:run-next": "tsx apps/agent-runtime/src/orchestration/campaign-cli.ts run-next --workspace .",
    "campaign:status": "tsx apps/agent-runtime/src/orchestration/campaign-cli.ts status --workspace .",
    "campaign:pause": "tsx apps/agent-runtime/src/orchestration/campaign-cli.ts pause --workspace .",
    "campaign:resume": "tsx apps/agent-runtime/src/orchestration/campaign-cli.ts resume --workspace .",
    "campaign:report": "tsx apps/agent-runtime/src/orchestration/campaign-cli.ts report --workspace .",
    "campaign:metrics": "tsx apps/agent-runtime/src/orchestration/campaign-cli.ts metrics --workspace .",
    "eval:phase4": "tsx apps/agent-runtime/src/evals/cli.ts --workspace .",
    "agent:dev": "npm run dev -w @hivo/agent-runtime",
    "web:dev": "npm run dev -w @hivo/desktop",
    "desktop:dev": "npm run tauri:dev -w @hivo/desktop",
    "dev": "node scripts/launch-desktop.mjs"
  }
}
