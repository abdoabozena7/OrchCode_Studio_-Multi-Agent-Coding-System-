  "dependencies": {
    "@orchcode/protocol": "file:../../packages/protocol",
    "fastify": "^5.2.1",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.8.3"
  }
}
