{
  "name": "@orchcode/agent-runtime",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "memory:index": "tsx src/memory/cli.ts index repo --workspace ../..",
    "memory:index-status": "tsx src/memory/cli.ts index status --workspace ../..",
    "memory:index-refresh": "tsx src/memory/cli.ts index refresh --workspace ../..",
    "memory:index-explain": "tsx src/memory/cli.ts index explain --workspace ../..",
    "memory:inspect": "tsx src/memory/cli.ts memory inspect --workspace ../..",
    "memory:status": "tsx src/memory/cli.ts memory status --workspace ../..",
    "memory:show-commands": "tsx src/memory/cli.ts memory show-commands --workspace ../..",
    "memory:clean-runs": "tsx src/memory/cli.ts memory clean-runs --workspace ../..",
    "memory:compact": "tsx src/memory/cli.ts memory compact --workspace ../..",
    "memory:lessons": "tsx src/memory/cli.ts memory lessons --workspace ../..",
    "memory:decisions": "tsx src/memory/cli.ts memory decisions --workspace ../..",
    "memory:failed-attempts": "tsx src/memory/cli.ts memory failed-attempts --workspace ../..",
    "memory:explain-task": "tsx src/memory/cli.ts memory explain-task --workspace ../..",
    "agentic:run": "tsx src/orchestration/cli.ts run-agentic-task --workspace ../..",
    "agentic:plan": "tsx src/orchestration/cli.ts plan-task --workspace ../..",
    "agentic:resume-run": "tsx src/orchestration/cli.ts resume-run --workspace ../..",
    "agentic:list-runs": "tsx src/orchestration/cli.ts list-runs --workspace ../..",
    "agentic:show-run": "tsx src/orchestration/cli.ts show-run --workspace ../..",
    "agentic:show-report": "tsx src/orchestration/cli.ts show-report --workspace ../..",
    "agentic:run-metrics": "tsx src/orchestration/cli.ts run-metrics --workspace ../..",
    "agentic:show-artifacts": "tsx src/orchestration/cli.ts show-artifacts --workspace ../..",
    "agentic:show-artifact": "tsx src/orchestration/cli.ts show-artifact --workspace ../..",
    "agentic:inspect-task": "tsx src/orchestration/cli.ts inspect-task --workspace ../..",
    "agentic:show-context-pack": "tsx src/orchestration/cli.ts show-context-pack --workspace ../..",
    "agentic:show-run-events": "tsx src/orchestration/cli.ts show-run-events --workspace ../..",
    "agentic:show-task-artifacts": "tsx src/orchestration/cli.ts show-task-artifacts --workspace ../..",
    "agentic:show-validation-logs": "tsx src/orchestration/cli.ts show-validation-logs --workspace ../..",
    "agentic:show-patch-history": "tsx src/orchestration/cli.ts show-patch-history --workspace ../..",
    "campaign:create": "tsx src/orchestration/campaign-cli.ts create --workspace ../..",
    "campaign:plan": "tsx src/orchestration/campaign-cli.ts plan --workspace ../..",
    "campaign:run-next": "tsx src/orchestration/campaign-cli.ts run-next --workspace ../..",
    "campaign:status": "tsx src/orchestration/campaign-cli.ts status --workspace ../..",
    "campaign:pause": "tsx src/orchestration/campaign-cli.ts pause --workspace ../..",
    "campaign:resume": "tsx src/orchestration/campaign-cli.ts resume --workspace ../..",
    "campaign:report": "tsx src/orchestration/campaign-cli.ts report --workspace ../..",
    "campaign:metrics": "tsx src/orchestration/campaign-cli.ts metrics --workspace ../..",
    "eval:phase4": "tsx src/evals/cli.ts --workspace ../..",
    "smoke:run-to-green": "tsx scripts/run-to-green-smoke.ts",
    "smoke:python-pygame-fallback": "tsx scripts/python-pygame-fallback-smoke.ts"
