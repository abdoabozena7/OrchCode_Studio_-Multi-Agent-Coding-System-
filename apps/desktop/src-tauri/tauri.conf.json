{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OrchCode Studio",
  "version": "0.1.0",
  "identifier": "studio.orchcode.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OrchCode Studio",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
